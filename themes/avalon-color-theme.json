{
  "name": "Avalon",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    // ── Editor ──────────────────────────────────────────
    "editor.background": "#0d0b1a",
    "editor.foreground": "#c5c0d6",
    "editor.lineHighlightBackground": "#1a1530",
    "editor.selectionBackground": "#3d2d6b88",
    "editor.selectionHighlightBackground": "#3d2d6b44",
    "editor.inactiveSelectionBackground": "#3d2d6b44",
    "editor.wordHighlightBackground": "#3d2d6b55",
    "editor.wordHighlightStrongBackground": "#3d2d6b77",
    "editor.findMatchBackground": "#5b3dbb55",
    "editor.findMatchHighlightBackground": "#5b3dbb33",
    "editor.hoverHighlightBackground": "#3d2d6b33",
    "editor.rangeHighlightBackground": "#1a153055",
    "editorCursor.foreground": "#a78bfa",
    "editorWhitespace.foreground": "#2a2445",
    "editorIndentGuide.background1": "#2a2445",
    "editorIndentGuide.activeBackground1": "#5b3dbb",
    "editorLineNumber.foreground": "#3d3560",
    "editorLineNumber.activeForeground": "#a78bfa",
    "editorBracketMatch.background": "#5b3dbb33",
    "editorBracketMatch.border": "#a78bfa",
    "editorGutter.addedBackground": "#6dd4a0",
    "editorGutter.modifiedBackground": "#7aa2f7",
    "editorGutter.deletedBackground": "#f77a8a",
    "editorOverviewRuler.border": "#1a1530",
    "editorRuler.foreground": "#2a2445",
    "editorError.foreground": "#f77a8a",
    "editorWarning.foreground": "#e0af68",
    "editorInfo.foreground": "#7aa2f7",

    // ── Editor Groups & Tabs ────────────────────────────
    "editorGroup.border": "#1e1835",
    "editorGroupHeader.tabsBackground": "#0a0814",
    "tab.activeBackground": "#0d0b1a",
    "tab.activeForeground": "#d4bfff",
    "tab.activeBorderTop": "#a78bfa",
    "tab.inactiveBackground": "#0a0814",
    "tab.inactiveForeground": "#5d5580",
    "tab.border": "#0a0814",
    "tab.hoverBackground": "#14112a",

    // ── Title Bar ───────────────────────────────────────
    "titleBar.activeBackground": "#080614",
    "titleBar.activeForeground": "#c5c0d6",
    "titleBar.inactiveBackground": "#080614",
    "titleBar.inactiveForeground": "#5d5580",
    "titleBar.border": "#1e1835",

    // ── Activity Bar ────────────────────────────────────
    "activityBar.background": "#080614",
    "activityBar.foreground": "#a78bfa",
    "activityBar.inactiveForeground": "#4a4070",
    "activityBarBadge.background": "#7c3aed",
    "activityBarBadge.foreground": "#ffffff",
    "activityBar.border": "#1e1835",

    // ── Side Bar ────────────────────────────────────────
    "sideBar.background": "#0a0814",
    "sideBar.foreground": "#9990b0",
    "sideBar.border": "#1e1835",
    "sideBarTitle.foreground": "#c5c0d6",
    "sideBarSectionHeader.background": "#0d0b1a",
    "sideBarSectionHeader.foreground": "#a78bfa",

    // ── Lists ───────────────────────────────────────────
    "list.activeSelectionBackground": "#2a1f55",
    "list.activeSelectionForeground": "#d4bfff",
    "list.inactiveSelectionBackground": "#1e1835",
    "list.inactiveSelectionForeground": "#c5c0d6",
    "list.hoverBackground": "#14112a",
    "list.hoverForeground": "#c5c0d6",
    "list.focusBackground": "#2a1f55",
    "list.highlightForeground": "#a78bfa",

    // ── Status Bar ──────────────────────────────────────
    "statusBar.background": "#080614",
    "statusBar.foreground": "#9990b0",
    "statusBar.border": "#1e1835",
    "statusBar.debuggingBackground": "#7c3aed",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.noFolderBackground": "#0a0814",
    "statusBarItem.hoverBackground": "#2a1f55",
    "statusBarItem.prominentBackground": "#7c3aed",
    "statusBarItem.prominentForeground": "#ffffff",
    "statusBarItem.remoteBackground": "#5b3dbb",
    "statusBarItem.remoteForeground": "#ffffff",

    // ── Panel ───────────────────────────────────────────
    "panel.background": "#0a0814",
    "panel.border": "#1e1835",
    "panelTitle.activeBorder": "#a78bfa",
    "panelTitle.activeForeground": "#d4bfff",
    "panelTitle.inactiveForeground": "#5d5580",

    // ── Terminal ────────────────────────────────────────
    "terminal.background": "#0a0814",
    "terminal.foreground": "#c5c0d6",
    "terminal.ansiBlack": "#1a1530",
    "terminal.ansiRed": "#f77a8a",
    "terminal.ansiGreen": "#6dd4a0",
    "terminal.ansiYellow": "#e0af68",
    "terminal.ansiBlue": "#7aa2f7",
    "terminal.ansiMagenta": "#bb9af7",
    "terminal.ansiCyan": "#7dcfff",
    "terminal.ansiWhite": "#c5c0d6",
    "terminal.ansiBrightBlack": "#4a4070",
    "terminal.ansiBrightRed": "#ff9eab",
    "terminal.ansiBrightGreen": "#95f0be",
    "terminal.ansiBrightYellow": "#f0d090",
    "terminal.ansiBrightBlue": "#a4c8ff",
    "terminal.ansiBrightMagenta": "#d4bfff",
    "terminal.ansiBrightCyan": "#a8e4ff",
    "terminal.ansiBrightWhite": "#e8e0f0",
    "terminalCursor.foreground": "#a78bfa",

    // ── Input ───────────────────────────────────────────
    "input.background": "#14112a",
    "input.foreground": "#c5c0d6",
    "input.border": "#2a2445",
    "input.placeholderForeground": "#5d5580",
    "inputOption.activeBorder": "#7c3aed",
    "inputOption.activeBackground": "#7c3aed33",
    "inputValidation.errorBackground": "#f77a8a22",
    "inputValidation.errorBorder": "#f77a8a",
    "inputValidation.warningBackground": "#e0af6822",
    "inputValidation.warningBorder": "#e0af68",
    "inputValidation.infoBackground": "#7aa2f722",
    "inputValidation.infoBorder": "#7aa2f7",

    // ── Buttons ─────────────────────────────────────────
    "button.background": "#7c3aed",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#6d28d9",
    "button.secondaryBackground": "#2a1f55",
    "button.secondaryForeground": "#d4bfff",
    "button.secondaryHoverBackground": "#3d2d6b",

    // ── Dropdown ────────────────────────────────────────
    "dropdown.background": "#14112a",
    "dropdown.foreground": "#c5c0d6",
    "dropdown.border": "#2a2445",

    // ── Scrollbar ───────────────────────────────────────
    "scrollbar.shadow": "#00000044",
    "scrollbarSlider.background": "#3d2d6b44",
    "scrollbarSlider.hoverBackground": "#3d2d6b88",
    "scrollbarSlider.activeBackground": "#5b3dbbaa",

    // ── Badge ───────────────────────────────────────────
    "badge.background": "#7c3aed",
    "badge.foreground": "#ffffff",

    // ── Progress Bar ────────────────────────────────────
    "progressBar.background": "#7c3aed",

    // ── Breadcrumb ──────────────────────────────────────
    "breadcrumb.foreground": "#5d5580",
    "breadcrumb.focusForeground": "#c5c0d6",
    "breadcrumb.activeSelectionForeground": "#a78bfa",
    "breadcrumbPicker.background": "#0d0b1a",

    // ── Minimap ─────────────────────────────────────────
    "minimap.findMatchHighlight": "#5b3dbb88",
    "minimap.selectionHighlight": "#3d2d6b88",
    "minimapGutter.addedBackground": "#6dd4a0",
    "minimapGutter.modifiedBackground": "#7aa2f7",
    "minimapGutter.deletedBackground": "#f77a8a",

    // ── Peek View ───────────────────────────────────────
    "peekView.border": "#5b3dbb",
    "peekViewEditor.background": "#0d0b1a",
    "peekViewEditor.matchHighlightBackground": "#5b3dbb44",
    "peekViewResult.background": "#0a0814",
    "peekViewResult.fileForeground": "#c5c0d6",
    "peekViewResult.lineForeground": "#9990b0",
    "peekViewResult.matchHighlightBackground": "#5b3dbb44",
    "peekViewResult.selectionBackground": "#2a1f55",
    "peekViewTitle.background": "#14112a",
    "peekViewTitleDescription.foreground": "#9990b0",
    "peekViewTitleLabel.foreground": "#d4bfff",

    // ── Merge Conflicts ─────────────────────────────────
    "merge.currentHeaderBackground": "#6dd4a033",
    "merge.currentContentBackground": "#6dd4a015",
    "merge.incomingHeaderBackground": "#7aa2f733",
    "merge.incomingContentBackground": "#7aa2f715",

    // ── Git Decoration ──────────────────────────────────
    "gitDecoration.addedResourceForeground": "#6dd4a0",
    "gitDecoration.modifiedResourceForeground": "#7aa2f7",
    "gitDecoration.deletedResourceForeground": "#f77a8a",
    "gitDecoration.untrackedResourceForeground": "#6dd4a0",
    "gitDecoration.ignoredResourceForeground": "#4a4070",
    "gitDecoration.conflictingResourceForeground": "#e0af68",

    // ── Diff Editor ─────────────────────────────────────
    "diffEditor.insertedTextBackground": "#6dd4a015",
    "diffEditor.removedTextBackground": "#f77a8a15",

    // ── Notifications ───────────────────────────────────
    "notificationCenter.border": "#1e1835",
    "notificationCenterHeader.background": "#0d0b1a",
    "notificationCenterHeader.foreground": "#c5c0d6",
    "notifications.background": "#14112a",
    "notifications.foreground": "#c5c0d6",
    "notifications.border": "#1e1835",
    "notificationLink.foreground": "#a78bfa",

    // ── Command Palette ─────────────────────────────────
    "quickInput.background": "#0d0b1a",
    "quickInput.foreground": "#c5c0d6",
    "quickInputList.focusBackground": "#2a1f55",
    "quickInputTitle.background": "#14112a",

    // ── Keybinding Label ────────────────────────────────
    "keybindingLabel.background": "#2a1f5588",
    "keybindingLabel.foreground": "#d4bfff",
    "keybindingLabel.border": "#5b3dbb44",
    "keybindingLabel.bottomBorder": "#5b3dbb44",

    // ── Settings ────────────────────────────────────────
    "settings.headerForeground": "#d4bfff",
    "settings.modifiedItemIndicator": "#7c3aed",
    "settings.focusedRowBackground": "#14112a",

    // ── Welcome Page ────────────────────────────────────
    "walkThrough.embeddedEditorBackground": "#0a0814",
    "welcomePage.background": "#0d0b1a",

    // ── Widget ──────────────────────────────────────────
    "editorWidget.background": "#0d0b1a",
    "editorWidget.border": "#1e1835",
    "editorSuggestWidget.background": "#0d0b1a",
    "editorSuggestWidget.border": "#1e1835",
    "editorSuggestWidget.foreground": "#c5c0d6",
    "editorSuggestWidget.highlightForeground": "#a78bfa",
    "editorSuggestWidget.selectedBackground": "#2a1f55",
    "editorHoverWidget.background": "#0d0b1a",
    "editorHoverWidget.border": "#1e1835",

    // ── Focus Border ────────────────────────────────────
    "focusBorder": "#5b3dbb88",
    "widget.shadow": "#00000066"
  },
  "tokenColors": [
    // ── Comments ────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4a4070",
        "fontStyle": "italic"
      }
    },

    // ── Strings ─────────────────────────────────────────
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#6dd4a0"
      }
    },
    {
      "name": "String Escape Characters",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Template String Expressions",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "string.template meta.template.expression"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },

    // ── Numbers & Constants ─────────────────────────────
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Boolean / Null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Constants",
      "scope": "constant.language",
      "settings": {
        "foreground": "#e0af68"
      }
    },

    // ── Keywords ────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression"],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "Control Flow",
      "scope": ["keyword.control.flow", "keyword.control.return", "keyword.control.conditional", "keyword.control.loop"],
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#7dcfff"
      }
    },

    // ── Storage / Types ─────────────────────────────────
    {
      "name": "Storage Types (let, const, var, class, function, etc.)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#bb9af7"
      }
    },

    // ── Functions ───────────────────────────────────────
    {
      "name": "Function Declarations",
      "scope": ["entity.name.function", "meta.function-call entity.name.function"],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "Function Parameters",
      "scope": ["variable.parameter", "meta.parameters"],
      "settings": {
        "foreground": "#e0af68",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Arrow Functions",
      "scope": "storage.type.function.arrow",
      "settings": {
        "foreground": "#7dcfff"
      }
    },

    // ── Classes / Types ─────────────────────────────────
    {
      "name": "Class Names",
      "scope": ["entity.name.type.class", "support.class"],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Interfaces & Type Names",
      "scope": ["entity.name.type", "entity.name.type.interface", "support.type"],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Type Parameters (Generics)",
      "scope": "entity.name.type.parameter",
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "Inherited Class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#7dcfff",
        "fontStyle": "italic"
      }
    },

    // ── Variables ───────────────────────────────────────
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#c5c0d6"
      }
    },
    {
      "name": "Object Properties",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"],
      "settings": {
        "foreground": "#a4c8ff"
      }
    },
    {
      "name": "Language Variables (this, self, super)",
      "scope": "variable.language",
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },

    // ── Support / Library ───────────────────────────────
    {
      "name": "Support Functions",
      "scope": "support.function",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "Support Constants",
      "scope": "support.constant",
      "settings": {
        "foreground": "#e0af68"
      }
    },

    // ── Punctuation ─────────────────────────────────────
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#9990b0"
      }
    },
    {
      "name": "Punctuation Brackets",
      "scope": [
        "punctuation.bracket",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#9990b0"
      }
    },

    // ── Tags (HTML/JSX) ─────────────────────────────────
    {
      "name": "HTML/JSX Tags",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": {
        "foreground": "#f77a8a"
      }
    },
    {
      "name": "Tag Brackets",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#5d5580"
      }
    },
    {
      "name": "HTML/JSX Attributes",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },

    // ── CSS ─────────────────────────────────────────────
    {
      "name": "CSS Properties",
      "scope": "support.type.property-name.css",
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "CSS Values",
      "scope": "support.constant.property-value.css",
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "CSS Units",
      "scope": "keyword.other.unit.css",
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "CSS Pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },

    // ── JSON ────────────────────────────────────────────
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },

    // ── Markdown ────────────────────────────────────────
    {
      "name": "Markdown Headings",
      "scope": ["heading.1.markdown", "heading.2.markdown", "heading.3.markdown", "heading.4.markdown", "heading.5.markdown", "heading.6.markdown", "markup.heading"],
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#e0af68",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#6dd4a0"
      }
    },

    // ── Regular Expressions ─────────────────────────────
    {
      "name": "Regex",
      "scope": "string.regexp",
      "settings": {
        "foreground": "#f77a8a"
      }
    },

    // ── Decorators / Annotations ────────────────────────
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#e0af68"
      }
    },

    // ── Imports / Modules ───────────────────────────────
    {
      "name": "Import / Export",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "Module Name",
      "scope": "entity.name.import",
      "settings": {
        "foreground": "#c5c0d6"
      }
    },

    // ── Python specific ─────────────────────────────────
    {
      "name": "Python Self",
      "scope": "variable.parameter.function.language.special.self.python",
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python Magic Methods",
      "scope": "support.function.magic.python",
      "settings": {
        "foreground": "#7dcfff"
      }
    },

    // ── Rust specific ───────────────────────────────────
    {
      "name": "Rust Lifetimes",
      "scope": "entity.name.type.lifetime.rust",
      "settings": {
        "foreground": "#e0af68",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust Macros",
      "scope": "entity.name.function.macro.rust",
      "settings": {
        "foreground": "#7dcfff",
        "fontStyle": "bold"
      }
    },

    // ── Go specific ─────────────────────────────────────
    {
      "name": "Go Package Name",
      "scope": "entity.name.package.go",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },

    // ── Misc ────────────────────────────────────────────
    {
      "name": "Namespace",
      "scope": "entity.name.namespace",
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Entity Name",
      "scope": "entity.name",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "YAML Keys",
      "scope": "entity.name.tag.yaml",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "TOML Keys",
      "scope": "keyword.key.toml",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "INI Keys",
      "scope": "keyword.other.definition.ini",
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "name": "Section Headers",
      "scope": "entity.name.section",
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#7dcfff",
    "class": "#7dcfff",
    "interface": "#7dcfff",
    "struct": "#7dcfff",
    "enum": "#7dcfff",
    "enumMember": "#e0af68",
    "function": "#7aa2f7",
    "method": "#7aa2f7",
    "macro": "#7dcfff",
    "variable": "#c5c0d6",
    "variable.readonly": "#c5c0d6",
    "parameter": { "foreground": "#e0af68", "italic": true },
    "property": "#a4c8ff",
    "property.readonly": "#a4c8ff",
    "namespace": "#7dcfff",
    "decorator": "#e0af68",
    "typeParameter": "#e0af68"
  }
}
